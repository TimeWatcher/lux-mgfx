export client fn registerTextFont(fontName, spec = nil) =
  textModule.registerFont(fontName, spec)

export client fn defineTextStyle(name, textStyle = nil) =
  textModule.defineStyle(name, textStyle)

export client fn getTextStyle(name) =
  textModule.getStyle(name)

export client fn resolveTextStyle(textStyle = nil) =
  textModule.resolveStyle(textStyle)

export client fn measureText(value, font = "DermaDefault") =
  textModule.measure(value, font)

export client fn measureTextBox(value, font, w, textStyle = nil) =
