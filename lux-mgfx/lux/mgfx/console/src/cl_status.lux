fn countsLine(label, counts) {
  local parts = {}
  for key, value in pairs(counts ?? {}) {
    if value ~= nil and value ~= 0 {
      parts[#parts + 1] = toString(key) .. "=" .. toString(value)
    }
  }

  tableSort(parts)
  printFn("[MGFX] " .. label .. ": " .. (#parts > 0 then tableConcat(parts, " ") else "none"))
}

fn shaderStatus(owner) {
  local statusFn = owner?.shaderStatus
  if statusFn ~= nil {
    return statusFn()
  }

  materialsPkg.shaderStatus(owner?._MaterialState)
}

fn profilerApi(owner) =
  owner?.Profiler

fn profilerRegistry() =
  globalTable.MGFX?._ProfilerRegistry?.items

fn collectProfilerRows(owner, methodName, limit = nil) {
  local rows = {}
  local registry = profilerRegistry()
  if registry ~= nil {
    for _, item in pairs(registry) {
      local api = item?.profiler
      local method = api?.[methodName]
      if method ~= nil {
        local instanceRows = method(limit)
        for index = 1, #(instanceRows ?? {}) {
          rows[#rows + 1] = instanceRows[index]
        }
      }
    }
  }

  if #rows == 0 {
    local profiler = profilerApi(owner)
    local method = profiler?.[methodName]
    if method ~= nil {
      rows = method(limit) ?? {}
    }
  }

  tableSort(rows, (a, b) => {
    local av = methodName == "RecentScopes" then (a.last ?? 0) else (a.avg ?? a.last ?? 0)
    local bv = methodName == "RecentScopes" then (b.last ?? 0) else (b.avg ?? b.last ?? 0)
    if av == bv {
      return toString(a.name ?? "") < toString(b.name ?? "")
    }
    av > bv
  })

  local numericLimit = toNumber(limit)
  if numericLimit ~= nil and numericLimit > 0 {
    while #rows > numericLimit {
      rows[#rows] = nil
    }
  }
  rows
}

fn profilerInstanceCount() {
  local registry = profilerRegistry()
  if registry == nil {
    return 0
  }

  local count = 0
  for _, item in pairs(registry) {
    if item?.profiler ~= nil {
      count += 1
    }
  }
  count
}

fn formatProfiler(owner) {
  local direct = profilerApi(owner)
  if direct ~= nil {
    return direct
  }

  local registry = profilerRegistry()
  if registry ~= nil {
    for _, item in pairs(registry) {
      if item?.profiler ~= nil {
        return item.profiler
      }
    }
  }

  nil
}

fn resetAllProfilers() {
  local registry = profilerRegistry()
  local count = 0
  if registry ~= nil {
    for _, item in pairs(registry) {
      local reset = item?.profiler?.Reset
      if reset ~= nil {
        reset()
        count += 1
      }
    }
  }
  count
}

fn textStatus(owner) {
  local snapshot = nil
  local snapshotFn = owner?.GetTextProfileSnapshot
  if snapshotFn ~= nil {
    snapshot = snapshotFn(false)
  }

  return snapshot ?? {}
}

fn textRendererStatus(owner) {
  local statusFn = owner?.GetTextRendererStatus
  if statusFn ~= nil {
    return statusFn()
  }

  {}
}

